# LinkedIn API Credentials
# Get these from your browser's cookies after logging into LinkedIn

# Main authentication token
LINKEDIN_LI_AT=your_li_at_token_here

# Session ID (starts with "ajax:")
LINKEDIN_JSESSIONID=ajax:your_jsessionid_here

# Optional: Override default settings
# PROFILE_IDENTIFIER=yolandyan
# MONTHS_TO_FETCH=6
# LOG_LEVEL=info

# Optional: Rate limiting configuration
# BATCH_DELAY_MS=1000              # Delay between batches (default: 1000ms)
# JITTER_PERCENT=30                # Random delay 0-30% to avoid detection (default: 30)
# RATE_LIMIT_INITIAL_DELAY_MS=2000 # Initial backoff on rate limit (default: 2000ms)
# RATE_LIMIT_MAX_DELAY_MS=120000   # Max backoff delay (default: 2 minutes)
# MAX_RETRIES=5                    # Max retries on rate limit (default: 5)
